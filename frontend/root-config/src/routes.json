{
  "routes": [
    {
      "path": "/",
      "app": "@lms/auth",
      "protected": false,
      "exact": true
    },
    {
      "path": "/login",
      "app": "@lms/auth",
      "protected": false
    },
    {
      "path": "/reset-password",
      "app": "@lms/auth",
      "protected": false
    },
    {
      "path": "/set-password",
      "app": "@lms/auth",
      "protected": false
    },
    {
      "path": "/dashboard",
      "app": "@lms/member-portal",
      "protected": true,
      "roles": ["MEMBER"]
    },
    {
      "path": "/staff",
      "app": "@lms/staff-portal",
      "protected": true,
      "roles": ["LIBRARIAN", "ADMIN"]
    }
  ]
}